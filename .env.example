# Supabase — Project Settings → API
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER prefixed with NEXT_PUBLIC). Used by the seed script and
# any privileged server work. Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the deployed site, used for absolute links in /llms.txt and
# OAuth redirects. e.g. https://your-app.vercel.app (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bearer token required by POST /api/agent/posts (server-only secret). Generate
# one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AGENT_API_TOKEN=
